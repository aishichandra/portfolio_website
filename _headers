# Cache static assets for 1 year (versioned URLs bust cache when you deploy)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/styles.css*
  Cache-Control: public, max-age=31536000, immutable

/scripts/*
  Cache-Control: public, max-age=31536000, immutable

/data/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# HTML: revalidate so users get latest page (versioned assets stay cached)
/
  Cache-Control: public, max-age=0, must-revalidate
